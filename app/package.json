{
  "name": "bonesofspring-main",
  "version": "1.10.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "yarn lint:js && yarn lint:css && yarn type-check",
    "lint:js": "eslint . --ext ts --ext tsx --ext js --ext mjs",
    "lint:css": "stylelint \"**/*.{css,ts}\"",
    "test": "TZ=UTC jest --config ./jest.config.js --collectCoverage --coverageDirectory=\"./coverage\" --coverageReporters=json --coverageReporters=lcov --coverageReporters=cobertura --ci --reporters=default --reporters=jest-junit --watchAll=false",
    "test:update": "cp .env-prod .env && jest -u && rm .env",
    "type-check": "yarn tsc --project tsconfig.json --pretty --noEmit",
    "analyze": "IS_ANALYZE_MODE_ON=1 next build",
    "prepare": "husky",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "PWDEBUG=1 playwright test",
    "e2e:codegen": "playwright codegen http://localhost:3000"
  },
  "dependencies": {
    "@babel/runtime": "^7.29.2",
    "@linaria/core": "^7.0.0",
    "@linaria/react": "^7.0.1",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/context-async-hooks": "^2.6.0",
    "@opentelemetry/core": "^2.6.0",
    "@opentelemetry/sdk-trace-base": "^2.6.0",
    "@reduxjs/toolkit": "^2.11.2",
    "@sentry/nextjs": "^10.44.0",
    "@wyw-in-js/babel-preset": "^1.0.6",
    "@wyw-in-js/transform": "^1.0.6",
    "axios": "^1.13.6",
    "msw": "^2.12.13",
    "next": "16.1.7",
    "next-global-css": "^1.3.1",
    "next-with-linaria": "^1.3.0",
    "postcss": "^8.5.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-redux": "^9.2.0"
  },
  "devDependencies": {
    "@bonesofspring/eslint-react": "^0.10.0",
    "@bonesofspring/stylelint-react": "^0.5.1",
    "@commitlint/config-conventional": "^20.5.0",
    "@linaria/postcss-linaria": "^7.0.0",
    "@next/bundle-analyzer": "^16.1.7",
    "@playwright/test": "^1.58.2",
    "@rspack/core": "^1.0.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@statoscope/webpack-plugin": "^5.29.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "commitlint": "^20.5.0",
    "dotenv": "^17.3.1",
    "eslint": "^9.39.2",
    "eslint-plugin-boundaries": "^6.0.0",
    "eslint-plugin-compat": "^7.0.1",
    "eslint-plugin-no-relative-import-paths": "^1.6.1",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "isomorphic-fetch": "^3.0.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "jest-junit": "^16.0.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "semantic-release": "^25.0.3",
    "stylelint": "^17.4.0",
    "typescript": "^5.9.3",
    "web-streams-polyfill": "^4.2.0",
    "webpack": "^5.0.0",
    "webpack-delete-sourcemaps-plugin": "^1.3.1"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  },
  "browserslist": [
    "chrome >= 111",
    "edge >= 111",
    "firefox >= 111",
    "safari >= 15",
    "ios_saf >= 15"
  ]
}
